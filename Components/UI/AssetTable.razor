@using SmartPortfolioManager.Models

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Symbol</th>
            <th>Type</th>
            <th>Current Price</th>
            <th>Created At</th>

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <th>Actions</th>
                </Authorized>
            </AuthorizeView>
        </tr>
    </thead>

    <tbody>
        @if (AssetList == null || !AssetList.Any())
        {
            <tr>
                <td colspan="5" class="text-center">No assets available.</td>
            </tr>
        }
        else
        {
            @foreach (var asset in AssetList)
            {
                <tr>
                    <td>@asset.Name</td>
                    <td>@asset.Symbol</td>
                    <td>@asset.Type</td>
                    <td>@asset.CurrentPrice.ToString("C")</td>
                    <td>@asset.CreatedAt.ToString("dd/MM/yyyy")</td>

                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <td>
                                <a href="/edit-asset/@asset.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => TriggerDelete(asset.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </Authorized>
                    </AuthorizeView>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    [Parameter]
    public List<Asset> AssetList { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnDeleteClicked { get; set; }

    private async Task TriggerDelete(int id)
    {
        await OnDeleteClicked.InvokeAsync(id);
    }
}