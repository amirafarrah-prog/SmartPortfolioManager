@page "/dashboard"
@rendermode InteractiveServer
@attribute [Authorize]

@using SmartPortfolioManager.Models
@using SmartPortfolioManager.Services
@using SmartPortfolioManager.Components.UI

@inject IPortfolioService PortfolioService

<PageTitle>Dashboard</PageTitle>

<div class="mb-4">
    <h2 class="dashboard-title">Portfolio Dashboard</h2>
    <p class="dashboard-subtitle">
        Stay updated on your investments with a clear view of portfolio value, performance, budget progress, and diversification.
    </p>
</div>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <KpiCard Title="Total Assets"
                 Value="@TotalAssets.ToString()"
                 BackgroundColorClass="bg-primary"
                 IconClass="bi-wallet2" />
    </div>

    <div class="col-md-3 mb-3">
        <KpiCard Title="Current Value"
                 Value="@CurrentValue.ToString("C")"
                 BackgroundColorClass="bg-success"
                 IconClass="bi-cash-stack" />
    </div>

    <div class="col-md-3 mb-3">
        <KpiCard Title="Total Invested"
                 Value="@TotalInvested.ToString("C")"
                 BackgroundColorClass="bg-info"
                 IconClass="bi-piggy-bank" />
    </div>

    <div class="col-md-3 mb-3">
        <KpiCard Title="Gain / Loss"
                 Value="@OverallGainLoss.ToString("C")"
                 BackgroundColorClass="@GainLossColor"
                 IconClass="bi-graph-up-arrow" />
    </div>
</div>

@if (CurrentBudget != null)
{
    <div class="card dashboard-card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">
                <i class="bi bi-cash-coin text-success"></i>
                Budget Usage
            </h5>
        </div>

        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-4 mb-3">
                    <h6 class="text-muted">Initial Budget</h6>
                    <h4>@CurrentBudget.InitialAmount.ToString("C")</h4>
                </div>

                <div class="col-md-4 mb-3">
                    <h6 class="text-muted">Total Invested</h6>
                    <h4>@TotalInvested.ToString("C")</h4>
                </div>

                <div class="col-md-4 mb-3">
                    <h6 class="text-muted">Remaining Budget</h6>
                    <h4 class="@(RemainingBudget >= 0 ? "text-success" : "text-danger")">
                        @RemainingBudget.ToString("C")
                    </h4>
                </div>
            </div>

            <hr />

            <p class="mb-0 text-muted">
                Monthly contribution planned:
                <strong>@CurrentBudget.MonthlyContribution.ToString("C")</strong>
            </p>

            @if (!string.IsNullOrWhiteSpace(CurrentBudget.Notes))
            {
                <p class="mb-0 mt-2 text-muted">
                    Notes:
                    <strong>@CurrentBudget.Notes</strong>
                </p>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info shadow-sm">
        <strong>Budget:</strong> No investment budget has been configured yet.
    </div>
}

<div class="card dashboard-card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">
            <i class="bi bi-robot text-primary"></i>
            AI Market Prediction Module
        </h5>
    </div>

    <div class="card-body">
        <p class="mb-2">
            Get a quick view of possible market trends and use them to support your investment decisions.
        </p>

        <p class="text-muted mb-3">
            Open the prediction tool to explore future price movement and compare it with your portfolio performance.
        </p>

        <a href="https://projetdl-jyujknkxwq6sdgtpuutb3v.streamlit.app/"
           target="_blank"
           class="btn btn-outline-primary">
            <i class="bi bi-box-arrow-up-right"></i>
            Open AI Prediction Module
        </a>
    </div>
</div>

<div class="alert @PortfolioHealthClass shadow-sm">
    <strong>Portfolio Health:</strong> @PortfolioHealthMessage
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card dashboard-card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-bar-chart-fill text-primary"></i>
                    Performance by Asset
                </h5>
            </div>

            <div class="card-body">
                @if (PerformanceStats == null || !PerformanceStats.Any())
                {
                    <p class="text-muted">No data available for performance chart.</p>
                }
                else
                {
                    <RadzenChart>
                        <RadzenColumnSeries Data="@PerformanceStats"
                                            CategoryProperty="AssetName"
                                            ValueProperty="GainLoss"
                                            Title="Gain / Loss" />
                        <RadzenValueAxis Formatter="@FormatMoney" />
                        <RadzenLegend Visible="false" />
                    </RadzenChart>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card dashboard-card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-pie-chart-fill text-success"></i>
                    Allocation by Type
                </h5>
            </div>

            <div class="card-body">
                @if (AllocationStats == null || !AllocationStats.Any())
                {
                    <p class="text-muted">No data available for allocation chart.</p>
                }
                else
                {
                    <RadzenChart>
                        <RadzenDonutSeries Data="@AllocationStats"
                                           CategoryProperty="TypeName"
                                           ValueProperty="TotalValue">
                            <TitleTemplate>
                                <div class="rz-donut-content">
                                    <div>Total</div>
                                    <div>@CurrentValue.ToString("C")</div>
                                </div>
                            </TitleTemplate>
                        </RadzenDonutSeries>
                    </RadzenChart>
                }
            </div>
        </div>
    </div>
</div>

<div class="card dashboard-card">
    <div class="card-header bg-white">
        <h5 class="mb-0">
            <i class="bi bi-table text-secondary"></i>
            Asset Performance Details
        </h5>
    </div>

    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Asset</th>
                    <th>Quantity</th>
                    <th>Current Value</th>
                    <th>Invested Amount</th>
                    <th>Gain / Loss</th>
                </tr>
            </thead>

            <tbody>
                @if (PerformanceStats == null || !PerformanceStats.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center">No performance data available.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in PerformanceStats)
                    {
                        <tr>
                            <td>@item.AssetName</td>
                            <td>@item.Quantity</td>
                            <td>@item.CurrentValue.ToString("C")</td>
                            <td>@item.InvestedAmount.ToString("C")</td>
                            <td class="@(item.GainLoss >= 0 ? "text-success" : "text-danger")">
                                @item.GainLoss.ToString("C")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private int TotalAssets;
    private decimal CurrentValue;
    private decimal TotalInvested;
    private decimal OverallGainLoss;

    private SmartPortfolioManager.Models.Budget? CurrentBudget;
    private decimal RemainingBudget;

    private List<AssetPerformanceStat> PerformanceStats = new();
    private List<AssetTypeAllocationStat> AllocationStats = new();

    private string GainLossColor => OverallGainLoss >= 0 ? "bg-success" : "bg-danger";

    private string PortfolioHealthMessage = "No portfolio data available yet.";
    private string PortfolioHealthClass = "alert-secondary";

    protected override async Task OnInitializedAsync()
    {
        TotalAssets = await PortfolioService.GetTotalAssetsAsync();
        CurrentValue = await PortfolioService.GetCurrentPortfolioValueAsync();
        TotalInvested = await PortfolioService.GetTotalInvestedAsync();
        OverallGainLoss = await PortfolioService.GetOverallGainLossAsync();

        CurrentBudget = await PortfolioService.GetBudgetAsync();

        if (CurrentBudget != null)
        {
            RemainingBudget = CurrentBudget.InitialAmount - TotalInvested;
        }

        PerformanceStats = await PortfolioService.GetPerformanceByAssetAsync();
        AllocationStats = await PortfolioService.GetAllocationByAssetTypeAsync();

        CalculatePortfolioHealth();
    }

    private void CalculatePortfolioHealth()
    {
        if (CurrentValue <= 0 || AllocationStats == null || !AllocationStats.Any())
        {
            PortfolioHealthMessage = "Add assets and transactions to analyze portfolio diversification.";
            PortfolioHealthClass = "alert-secondary";
            return;
        }

        var maxAllocation = AllocationStats.Max(a => a.TotalValue);
        var maxPercentage = maxAllocation / CurrentValue * 100;

        if (maxPercentage > 70)
        {
            PortfolioHealthMessage = $"High concentration detected: one asset type represents {maxPercentage:F1}% of the portfolio.";
            PortfolioHealthClass = "alert-danger";
        }
        else if (maxPercentage > 50)
        {
            PortfolioHealthMessage = $"Moderate concentration: one asset type represents {maxPercentage:F1}% of the portfolio.";
            PortfolioHealthClass = "alert-warning";
        }
        else
        {
            PortfolioHealthMessage = "Good diversification between asset types.";
            PortfolioHealthClass = "alert-success";
        }
    }

    private string FormatMoney(object value)
    {
        return $"{Convert.ToDecimal(value):C}";
    }
}