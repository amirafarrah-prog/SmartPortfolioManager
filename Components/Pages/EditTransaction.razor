@page "/edit-transaction"
@page "/edit-transaction/{Id:int}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@using SmartPortfolioManager.Models
@using SmartPortfolioManager.Models.Enums
@using SmartPortfolioManager.Services

@inject IPortfolioService PortfolioService
@inject NavigationManager NavigationManager

<PageTitle>Edit Transaction</PageTitle>

<h3>@(Id.HasValue ? "Edit Transaction" : "Add New Transaction")</h3>

@if (CurrentTransaction == null || AssetList == null)
{
    <p><em>Loading form...</em></p>
}
else
{
    <EditForm Model="CurrentTransaction" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="mb-3">
            <label class="form-label">Asset:</label>
            <InputSelect @bind-Value="CurrentTransaction.AssetId" class="form-select">
                <option value="0">-- Select an asset --</option>
                @foreach (var asset in AssetList)
                {
                    <option value="@asset.Id">@asset.Name (@asset.Symbol)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => CurrentTransaction.AssetId)" class="text-danger" />
        </div>

        <div class="mb-3">
            <label class="form-label">Transaction Type:</label>
            <InputSelect @bind-Value="CurrentTransaction.Type" class="form-select">
                @foreach (var type in Enum.GetValues<TransactionType>())
                {
                    <option value="@type">@type</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => CurrentTransaction.Type)" class="text-danger" />
        </div>

        <div class="mb-3">
            <label class="form-label">Quantity:</label>
            <InputNumber @bind-Value="CurrentTransaction.Quantity" class="form-control" />
            <ValidationMessage For="@(() => CurrentTransaction.Quantity)" class="text-danger" />
        </div>

        <div class="mb-3">
            <label class="form-label">Price:</label>
            <InputNumber @bind-Value="CurrentTransaction.Price" class="form-control" />
            <ValidationMessage For="@(() => CurrentTransaction.Price)" class="text-danger" />
        </div>

        <div class="mb-3">
            <label class="form-label">Notes:</label>
            <InputTextArea @bind-Value="CurrentTransaction.Notes" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/transactions" class="btn btn-secondary">Cancel</a>
    </EditForm>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private Transaction? CurrentTransaction;
    private List<Asset>? AssetList;

    protected override async Task OnInitializedAsync()
    {
        AssetList = await PortfolioService.GetAssetsAsync();

        if (Id.HasValue)
        {
            CurrentTransaction = await PortfolioService.GetTransactionByIdAsync(Id.Value);
        }

        if (CurrentTransaction == null)
        {
            CurrentTransaction = new Transaction();
        }
    }

    private async Task HandleValidSubmit()
    {
        if (CurrentTransaction == null)
        {
            return;
        }

        if (Id.HasValue)
        {
            await PortfolioService.UpdateTransactionAsync(CurrentTransaction);
        }
        else
        {
            await PortfolioService.AddTransactionAsync(CurrentTransaction);
        }

        NavigationManager.NavigateTo("/transactions");
    }
}